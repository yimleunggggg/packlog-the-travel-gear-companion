# Data backend selector: "local" | "supabase"
VITE_DATA_BACKEND=local

# Supabase config (required when VITE_DATA_BACKEND=supabase)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Same vars enable lazy auth (magic link + Google OAuth). In Supabase Dashboard → Authentication:
# - Enable Email + Google provider
# - Site URL: your dev origin (e.g. http://localhost:5173)
# - Redirect URLs: add http://localhost:5173/auth/callback and your production /auth/callback

# Logical workspace key (use different values for dev/staging/prod isolation)
VITE_PACKLOG_WORKSPACE=packlog-dev

# Client tier sent to `/api/ai/*` JSON body (`subscriptionTier`). Use `pro` when testing Pro-gated AI against a real backend.
# VITE_PACKLOG_SUBSCRIPTION_TIER=free

# Optional: AI weight hint API — POST JSON { "category", "nameHint" } (response: { midG, lowG, highG } in grams). Unset = use local heuristic in app.
# VITE_WEIGHT_AI_URL=

# --- Server-only (Wrangler secrets / Node dev env) — never prefix with VITE_ ---
# Anthropic Messages API for `/api/ai/parse-trip` (and future actions).
# ANTHROPIC_API_KEY=
# Optional model id (default in code: claude-sonnet-4-20250514).
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Dev-only: allow parse-trip without Pro when body tier is free (still requires ANTHROPIC_API_KEY).
# PACKLOG_AI_ALLOW_PARSE_TRIP=1
# Dev-only: allow AI screenshot import without Pro (server checks this env; see ai-route-handlers).
# PACKLOG_AI_ALLOW_VISION_IMPORT=1
# Dev-only: allow `/api/ai/import-url` (fetch page → plain text → Claude) without Pro.
# PACKLOG_AI_ALLOW_IMPORT_URL=1
