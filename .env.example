# Data backend selector: "local" | "supabase"
VITE_DATA_BACKEND=local

# Supabase config (required when VITE_DATA_BACKEND=supabase)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Logical workspace key (use different values for dev/staging/prod isolation)
VITE_PACKLOG_WORKSPACE=packlog-dev
